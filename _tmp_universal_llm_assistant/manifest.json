{
  "manifest_version": 3,
  "name": "Universal LLM Assistant",
  "version": "9.1.6",
  "description": "Assistente IA universal — LLM local (ai-core), LLM customizado e Cloudflare Workers AI",

  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "videoCapture",
    "audioCapture"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://127.0.0.1:8010/*",
    "http://127.0.0.1:32123/*",
    "http://localhost:3000/*",
    "http://localhost:32123/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "bg.js"
  },

  "action": {
    "default_title": "Universal LLM Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "side_panel": {
    "default_path": "panel.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/shared.js", "content/recording.js", "content/replay.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
