# Integration Kit
# Nome curto do pacote replicavel.
INTEGRATION_KIT_NAME=freshworks-supabase-starter
# Slug do workspace ou nicho atual.
INTEGRATION_WORKSPACE_SLUG=meu-workspace
# Vertical do projeto que sera replicado.
INTEGRATION_VERTICAL=servicos

# Supabase
# URL do projeto Supabase.
SUPABASE_URL=https://seu-projeto.supabase.co
# Project ref usado no MCP do Supabase.
SUPABASE_PROJECT_REF=abcdefghijklmnopqrst
# Service role para bootstrap, sync e admin APIs.
SUPABASE_SERVICE_ROLE_KEY=
# Chave anonima usada no frontend.
SUPABASE_ANON_KEY=
# Alias frontend da URL do Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# Alias frontend da anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GitHub
# Owner da organizacao ou usuario do repositorio.
GITHUB_REPO_OWNER=sua-org
# Nome do repositorio alvo.
GITHUB_REPO_NAME=seu-repo
# Branch principal padrao.
GITHUB_DEFAULT_BRANCH=main
# Opcional para integracoes GitHub App/MCP.
GITHUB_APP_INSTALLATION_ID=

# Freshworks
# Base principal da org no Freshworks.
FRESHWORKS_ORG_BASE_URL=https://sua-org.myfreshworks.com
# Base do CRM Sales API.
FRESHSALES_API_BASE=https://sua-org.myfreshworks.com/crm/sales/api
# Token legado do Freshsales, opcional quando usar OAuth.
FRESHSALES_API_KEY=
# Client id OAuth do Freshsales/Freshworks.
FRESHSALES_OAUTH_CLIENT_ID=
# Client secret OAuth do Freshsales/Freshworks.
FRESHSALES_OAUTH_CLIENT_SECRET=
# Refresh token para automatizar syncs.
FRESHSALES_REFRESH_TOKEN=
# Access token opcional para diagnostico manual.
FRESHSALES_ACCESS_TOKEN=
# Callback OAuth. Se vazio, usa a Edge Function /functions/v1/oauth.
FRESHSALES_REDIRECT_URI=
# Scopes OAuth do Freshsales.
FRESHSALES_SCOPES=freshsales.deals.view freshsales.deals.create freshsales.contacts.view freshsales.contacts.create freshsales.settings.fields.view

# Freshdesk
# Dominio/base da conta Freshdesk.
FRESHDESK_DOMAIN=https://sua-conta.freshdesk.com
# API key do Freshdesk.
FRESHDESK_API_KEY=
# Base para links de tickets no portal.
FRESHDESK_PORTAL_TICKET_BASE_URL=https://sua-conta.freshdesk.com/support/tickets
# URL do formulario novo ticket.
FRESHDESK_NEW_TICKET_URL=https://sua-conta.freshdesk.com/support/tickets/new

# Freshchat
# Base API do Freshchat.
FRESHCHAT_API_BASE=https://msdk.eu.freshchat.com
# API key do Freshchat quando aplicavel.
FRESHCHAT_API_KEY=
# App token do Freshchat.
FRESHCHAT_APP_TOKEN=

# Frontend
# Script embed do widget Freshworks.
NEXT_PUBLIC_FRESHWORKS_WIDGET_SCRIPT_URL=//fw-cdn.com/seu-widget.js
# Habilita o widget de chat.
NEXT_PUBLIC_FRESHWORKS_WIDGET_CHAT=false
