{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Cloudflare Pages Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:pages"],
      "port": 8788
    },
    {
      "name": "Cloudflare Worker - HMADV Process AI",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["wrangler", "dev", "--config", "workers/hmadv-process-ai/wrangler.toml"],
      "port": 8787
    }
    {
      "name": "Build",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "port": null
    },
    {
      "name": "Deploy to Cloudflare Pages",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["wrangler", "pages", "deploy", "out", "--project-name=newgit-pages"],
      "port": null
    }
  ]
}
