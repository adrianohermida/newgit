# Exemplo de arquivo .env para Dotobot Copilot + AI Task + ai-core
# Preencha os valores conforme os segredos já cadastrados no Cloudflare Pages

# --- SUPABASE ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- DOTOBOT / AI ---
# IMPORTANTE:
# O mesmo valor de DOTOBOT_SUPABASE_EMBED_SECRET precisa existir:
# 1. no app/web (Cloudflare Pages ou ambiente local que chama o healthcheck)
# 2. na Edge Function supabase/functions/dotobot-embed
# Se os valores divergirem, o healthcheck mostrará "Authentication error".
DOTOBOT_SUPABASE_EMBED_SECRET=
DOTOBOT_SUPABASE_EMBED_FUNCTION=dotobot-embed
DOTOBOT_SUPABASE_EMBEDDING_MODEL=gte-small
DOTOBOT_SUPABASE_MEMORY_TABLE=dotobot_memory_embeddings
DOTOBOT_EMBEDDING_MODEL=
DOTOBOT_OBSIDIAN_VAULT_PATH=
DOTOBOT_VECTORIZE_INDEX=

# --- LLM PROVIDERS ---
# Modo offline local:
# quando ativo, o catalogo administrativo prioriza apenas o provider `local`
# e marca os providers de nuvem como desabilitados.
LAWDESK_OFFLINE_MODE=false
NEXT_PUBLIC_LAWDESK_OFFLINE_MODE=false

# Nuvem principal (backend atual)
LAWDESK_DEFAULT_PROVIDER=gpt
PROCESS_AI_BASE=
LAWDESK_AI_BASE_URL=
HMDAV_AI_SHARED_SECRET=

# LLM local / própria (compatível com /v1/messages do ai-core runtime)
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=
LOCAL_LLM_AUTH_TOKEN=
LOCAL_LLM_MODEL=
LOCAL_LLM_MAX_TOKENS=1400

# Alternativa compatível com o runtime
LLM_BASE_URL=
LLM_API_KEY=
LLM_AUTH_TOKEN=
LLM_MODEL=
LLM_MAX_TOKENS=1400

# ai-core local runtime (quando o provider `local` apontar para o servidor Python local)
AICORE_API_BASE_URL=http://127.0.0.1:8000
AICORE_LOCAL_LLM_BASE_URL=
AICORE_LOCAL_LLM_API_KEY=
AICORE_LOCAL_LLM_AUTH_TOKEN=
AICORE_LOCAL_LLM_MODEL=aetherlab-legal-local-v1
AICORE_LOCAL_LLM_MAX_TOKENS=1400
AICORE_CLOUD_BASE_URL=
AICORE_CLOUD_API_KEY=
AICORE_CLOUD_AUTH_TOKEN=
AICORE_CLOUD_MODEL=aetherlab-legal-v1
AICORE_CLOUD_MAX_TOKENS=1400
AI_CORE_DEFAULT_PROVIDER=local
AICORE_OFFLINE_MODE=false

# Universal LLM Assistant / extensao local
UNIVERSAL_LLM_EXTENSION_BASE_URL=http://127.0.0.1:32123
UNIVERSAL_LLM_DEFAULT_BASE_PATH=

# Cloudflare Workers AI
CLOUDFLARE_WORKERS_AI_ENABLED=
CLOUDFLARE_WORKERS_AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# Endpoint custom compatível com /v1/messages
# Pode reaproveitar o mesmo worker HMADV IA.
# Exemplo:
# CUSTOM_LLM_BASE_URL=https://ai.hermidamaia.adv.br
# CUSTOM_LLM_AUTH_TOKEN=<mesmo valor de HMDAV_AI_SHARED_SECRET>
# CUSTOM_LLM_MODEL=<modelo interno desejado>
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_AUTH_TOKEN=
CUSTOM_LLM_MODEL=
CUSTOM_LLM_MAX_TOKENS=1400

# --- CLOUDFLARE ---
CLOUDFLARE_WORKER_ACCOUNT_ID=
CLOUDFLARE_WORKER_API_TOKEN=
CLOUDFLARE_KV_NAMESPACE=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_S3_API=
CLOUDFLARE_VECTORIZE_INDEX=

# --- FRESHCHAT / FRESHDESK / FRESHSALES ---
FRESHCHAT_API_BASE=
FRESHCHAT_API_KEY=
FRESHCHAT_APP_TOKEN=
FRESHCHAT_ENCRYPTED_KEY=
FRESHCHAT_ENCRYPTION_KEY=
FRESHCHAT_JWT_SECRET=
FRESHCHAT_TOKEN=
FRESHCHAT_WEB_MESSENGER_HOST=
FRESHCHAT_WEB_MESSENGER_TOKEN=
FRESHDESK_API_KEY=
FRESHDESK_DOMAIN=
FRESHDESK_NEW_TICKET_URL=
FRESHDESK_PORTAL_TICKET_BASE_URL=
FRESHSALES_API_BASE=
FRESHSALES_API_KEY=
FRESHSALES_OAUTH_CLIENT_ID=
FRESHSALES_OAUTH_CLIENT_SECRET=
FRESHSALES_OAUTH_CONTACTS_CLIENT_ID=
FRESHSALES_OAUTH_CONTACTS_CLIENT_SECRET=
FRESHSALES_ORG_DOMAIN=
FRESHSALES_REDIRECT_URI=
FRESHSALES_CONTACTS_SCOPES=
FRESHSALES_SCOPES=
FRESHSALES_BILLING_DEAL_FIELD_MAP=
FRESHSALES_DEFAULT_DEAL_STAGE_ID=
FRESHSALES_FINANCE_ACCOUNT_PROCESS_FIELDS=
FRESHSALES_FINANCE_ACCOUNT_STATUS_FIELDS=
FRESHSALES_FINANCE_DEAL_STAGE_FIELDS=
FRESHSALES_FINANCE_DEAL_TYPE_FIELDS=

# --- GOOGLE ---
GOOGLE_ACCESS_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# --- HMADV / LAWDESK ---
# Segredo compartilhado entre Pages e o worker `hmadv-process-ai`.
# Mantenha o mesmo valor entre app e worker. O runtime aceita:
# HMDAV_AI_SHARED_SECRET, HMADV_AI_SHARED_SECRET ou LAWDESK_AI_SHARED_SECRET.
HMDAV_AI_SHARED_SECRET=
HMADV_AI_SHARED_SECRET=
LAWDESK_AI_SHARED_SECRET=
HMADV_RUNNER_TOKEN=
HMADV_RUNNER_URL=
FREDDY_ACTION_SHARED_SECRET=
