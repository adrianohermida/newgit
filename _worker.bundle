      parts.push(`Email principal: ${contact.email || normalizeArray(contact.emails)[0]}.`);
    }
    if (contact.mobile_number || contact.phone_number) {
      parts.push(`Telefone: ${contact.mobile_number || contact.phone_number}.`);
