      update[config.lifecycleField] = mappedValue(config, "lifecycle", "Triagem");
      update[config.meetingField] = getEventMeetingStage(eventType, env);
      break;
    case "confirmed":
      update[config.lifecycleField] = mappedValue(config, "lifecycle", "Conectado");
      update[config.meetingField] = getEventMeetingStage(eventType, env);
      break;
    case "cancelled":
    case "rescheduled":
    case "no_show":
      update[config.meetingField] = getEventMeetingStage(eventType, env);
