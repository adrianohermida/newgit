  params.set(
    "select",
    "id,nome,email,telefone,area,data,hora,status,observacoes,google_event_id,zoom_meeting_id,zoom_join_url,created_at,updated_at"
  );
  params.set("order", "data.desc,hora.desc");
  if (filters.status) {
    params.set("status", `eq.${filters.status}`);
  }
  if (filters.dateFrom) {
    params.append("data", `gte.${filters.dateFrom}`);
  }
  if (filters.dateTo) {
    params.append("data", `lte.${filters.dateTo}`);
  }
  if (filters.limit) {
    params.set("limit", String(filters.limit));
  }
  return `agendamentos?${params.toString()}`;
}
