      const data = await listUnlinkedPartes(context.env, {
        page: Number(url.searchParams.get("page") || 1),
        pageSize: Number(url.searchParams.get("pageSize") || 20),
        query: String(url.searchParams.get("query") || "")
      });
      return jsonOk2({ data });
    }
