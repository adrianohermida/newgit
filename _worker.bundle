          activityId,
          appointmentId
        });
        activitiesCreated += 1;
        audienciasUpdated += 1;
        row.activities_criadas += 1;
        row.audiencias_atualizadas += 1;
        if (row.details.length < 5) {
          row.details.push({
            audiencia_id: audiencia.id,
