async function fetchFreshsalesActivities(env, { page = 1, perPage = 10 } = {}) {
  const token = cleanEnvValue4(env.FRESHSALES_API_KEY);
  const accessToken = cleanEnvValue4(env.FRESHSALES_ACCESS_TOKEN);
