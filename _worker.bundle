  const hasMovements = movements.length > 0 || Number(process2?.movement_count || 0) > 0 || Boolean(process2?.latest_movement);
  const hasPublications = publications.length > 0 || Boolean(process2?.latest_publication);
  const hasParts = parts.length > 0;
