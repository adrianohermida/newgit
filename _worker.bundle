  }
  if (documents.length) {
    parts.push(`Documentos relacionados: ${documents.length}.`);
  }
  if (activities.length) {
    parts.push(`Atividades recentes: ${activities.slice(0, 4).map((item) => item?.title || item?.subject || item?.type_name || item?.id).filter(Boolean).join(", ")}.`);
  }
