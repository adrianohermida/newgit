{
  "getSalesAccounts": {
    "schema": {
      "method": "GET",
      "host": "FRESHSALES_ORG_DOMAIN",
      "path": "/crm/sales/api/contacts/<%= contact_id %>/sales_accounts",
      "headers": {
        "Authorization": "Authtoken=<%= access_token %>",
        "Content-Type": "application/json"
      }
    },
    "options": {
      "oauth": "freshsales"
    }
  }
}
