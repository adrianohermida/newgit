{
  "name": "newgit",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:pages": "npm run build:pages && npx wrangler pages dev out --project-name=newgit-pages",
    "build:core": "node scripts/guard-next-build-lock.cjs",
    "build": "set AUTO_DEPLOY_WRANGLER=1&& set ALLOW_STATIC_ONLY_PAGES_DEPLOY=1&& npm run build:core && node scripts/normalize-pages-export-assets.js && node scripts/copy-manual-to-public.js && npm run deploy:pages",
    "build:pages": "node scripts/build-pages-static.cjs",
    "diagnose:pages-assets": "node scripts/diagnose-pages-export-assets.cjs",
    "deploy:pages": "npm run build:pages && node scripts/guard-pages-static-deploy.cjs && npx wrangler pages deploy out --project-name=newgit-pages --branch main",
    "deploy:hmadv-ai": "powershell -ExecutionPolicy Bypass -File scripts/deploy-hmadv-process-ai.ps1",
    "release:cf": "powershell -ExecutionPolicy Bypass -File scripts/release-cloudflare.ps1",
    "release:auto": "powershell -ExecutionPolicy Bypass -File scripts/release-cloudflare.ps1 -UseGitHubWorkerDeploy",
    "package:chat-ui-main-transfer": "powershell -ExecutionPolicy Bypass -File scripts/package-chat-ui-main-transfer.ps1",
    "diagnose:hmadv-ai": "powershell -ExecutionPolicy Bypass -File scripts/diagnose-hmadv-process-ai.ps1",
    "diagnose:hmadv-publicacoes": "node scripts/hmadv-validate-publicacoes-runtime.js",
    "drain:hmadv-publicacoes": "node scripts/hmadv-drain-publicacoes-freshsales.js",
    "diagnose:local-llm": "powershell -ExecutionPolicy Bypass -File scripts/diagnose-local-llm.ps1",
    "doctor:offline-local": "powershell -ExecutionPolicy Bypass -File scripts/doctor-local-offline-stack.ps1",
    "diagnose:supabase-local": "powershell -ExecutionPolicy Bypass -File scripts/doctor-local-offline-stack.ps1",
    "bootstrap:supabase-local": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-supabase-local.ps1",
    "bootstrap:offline-local": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-offline-local.ps1",
    "bootstrap:offline-local-full": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-offline-local.ps1 -IncludeSupabaseLocal",
    "setup:supabase-cli-local": "npm install --save-dev supabase",
    "supabase:start-local": "npx supabase start",
    "env:load-local": "powershell -ExecutionPolicy Bypass -Command \". .\\scripts\\load-local-env.ps1 -Path .local.supabase.env\"",
    "setup:ai-core-local": "powershell -ExecutionPolicy Bypass -Command \"Set-Location ai-core; python -m pip install -e .\"",
    "setup:aetherlab-local-model": "powershell -ExecutionPolicy Bypass -File scripts/setup-aetherlab-local-model.ps1",
    "start:ai-core-local": "powershell -ExecutionPolicy Bypass -File scripts/start-ai-core-local.ps1",
    "start:universal-llm-extension": "powershell -ExecutionPolicy Bypass -File scripts/start-universal-llm-extension.ps1",
    "diagnose:pages-admin": "powershell -ExecutionPolicy Bypass -File scripts/diagnose-pages-admin-runtime.ps1",
    "audit:lawdesk-env": "powershell -ExecutionPolicy Bypass -File scripts/audit-lawdesk-runtime-env.ps1",
    "verify:lawdesk-stack": "powershell -ExecutionPolicy Bypass -File scripts/postdeploy-verify-lawdesk-stack.ps1",
    "gate:lawdesk-stack": "powershell -ExecutionPolicy Bypass -File scripts/release-gate-lawdesk.ps1",
    "setup:hmadv-ai": "powershell -ExecutionPolicy Bypass -File scripts/setup-hmadv-process-ai.ps1",
    "start": "node .next/standalone/server.js",
    "import:hmadv-billing": "node scripts/import-hmadv-billing-csv.js",
    "import:billing-indices": "node scripts/import-billing-indices.js",
    "materialize:hmadv-billing": "node scripts/materialize-hmadv-billing.js",
    "discover:freshsales-billing-fields": "node scripts/discover-freshsales-billing-fields.js",
    "diagnose:freshsales-auth": "node scripts/diagnose-freshsales-auth.js",
    "authorize:freshsales": "node scripts/freshsales-authorize-url.js",
    "exchange:freshsales-code": "node scripts/exchange-freshsales-auth-code.js",
    "export:freshsales-accounts-import": "node scripts/export-freshsales-sales-accounts-import.js",
    "export:freshsales-deals-import": "node scripts/export-freshsales-deals-import.js",
    "bootstrap:hmadv-contacts": "node scripts/bootstrap-hmadv-contacts.js",
    "backfill:hmadv-accounts": "node scripts/backfill-hmadv-accounts.js",
    "orchestrate:hmadv-billing": "node scripts/orchestrate-hmadv-billing.js",
    "process:hmadv-crm-events": "node scripts/process-hmadv-crm-events.js",
    "publish:hmadv-deals": "node scripts/publish-hmadv-deals.js",
    "preflight:hmadv-billing": "node scripts/preflight-hmadv-billing.js",
    "refresh:freshsales-token": "node scripts/refresh-freshsales-token.js",
    "reconcile:hmadv-contacts": "node scripts/reconcile-hmadv-contacts.js",
    "reconcile:hmadv-processes": "node scripts/reconcile-hmadv-processes.js",
    "reprocess:hmadv-billing": "node scripts/reprocess-hmadv-billing.js",
    "retry:hmadv-deals": "node scripts/retry-hmadv-deals.js",
    "integration:init": "node scripts/integration-init.js",
    "integration:doctor": "node scripts/integration-doctor.js",
    "integration:authorize-url": "node scripts/integration-authorize-url.js",
    "integration:export-config": "node scripts/integration-export-config.js",
    "integration:validate": "node scripts/integration-validate.js",
    "integration:bootstrap": "node scripts/integration-bootstrap.js",
    "integration:go": "node scripts/integration-bootstrap.js --execute-supabase",
    "integration:seed-products": "node scripts/integration-seed-products.js",
    "integration:sync": "node scripts/integration-sync.js",
    "integration:ops": "node scripts/integration-bidirectional-sync.js",
    "test:integration-kit": "node tests/integration-kit/bootstrap-preview.test.cjs",
    "test:integration-kit-validate": "node tests/integration-kit/integration-validate.test.cjs",
    "test:integration-kit-guards": "node tests/integration-kit/bootstrap-cli-guards.test.cjs",
    "report:hmadv-reconciliation": "node scripts/export-hmadv-reconciliation-report.js",
    "report:hmadv-ops": "node scripts/report-hmadv-ops.js",
    "seed:hmadv-products": "node scripts/seed-hmadv-products.js",
    "sync:freshsales-contacts": "node scripts/sync-freshsales-contacts.js",
    "sync:freshsales-deals": "node scripts/sync-freshsales-deals.js",
    "sync:freshsales-products": "node scripts/sync-freshsales-products.js",
    "import:hmadv-freshsales-deals": "node scripts/import-hmadv-freshsales-deals.js",
    "sync:hmadv-deals-bidirectional": "node scripts/sync-hmadv-deals-bidirectional.js",
    "gh-pages": "GITHUB_PAGES=true next build && rm -rf docs && mkdir docs && cp -r out/* docs/ && touch docs/.nojekyll",
    "test:integration": "node scripts/test-integration.js",
    "test:dotobot": "node --experimental-vm-modules tests/lawdesk/dotobot-backend.test.cjs",
    "test:dotobot-router": "node --experimental-vm-modules tests/lawdesk/dotobot-direct-router.test.cjs",
    "test:admin-lawdesk-chat-route": "node --experimental-vm-modules tests/lawdesk/admin-lawdesk-chat-route.test.cjs",
    "test:functions-admin-rag-route": "node --experimental-vm-modules tests/lawdesk/functions-admin-dotobot-rag-health-route.test.cjs",
    "test:functions-admin-providers-route": "node --experimental-vm-modules tests/lawdesk/functions-admin-lawdesk-providers-route.test.cjs",
    "test:providers-health": "node --experimental-vm-modules tests/lawdesk/providers-health.test.cjs",
    "test:admin-providers-route": "node --experimental-vm-modules tests/lawdesk/admin-lawdesk-providers-route.test.cjs",
    "test:aitask-ui": "node --experimental-vm-modules tests/lawdesk/aitask-ui-modules.test.cjs",
    "test:market-ads-ui": "node tests/lawdesk/market-ads-module-structure.test.cjs",
    "test:llm-test": "node --experimental-vm-modules tests/lawdesk/llm-test-console.test.cjs",
    "test:task-runs": "node --experimental-vm-modules tests/lawdesk/task-runs-backend.test.cjs",
    "test:console-log": "node --experimental-vm-modules tests/lawdesk/console-log-utils.test.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "framer-motion": "^12.35.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.577.0",
    "next": "latest",
    "nodemailer": "^8.0.2",
    "react": "latest",
    "react-dom": "latest",
    "react-responsive": "^10.0.1",
    "react-transition-group": "^4.4.5",
    "react-window": "^1.8.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.0",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "supabase": "^2.89.1",
    "tailwindcss": "^3.0.0",
    "typescript": "6.0.2",
    "wrangler": "^4.76.0"
  }
}
