# Stack offline local - exemplo minimo
# Copie para um arquivo local seu e ajuste os caminhos/portas conforme necessario.

LAWDESK_OFFLINE_MODE=true
NEXT_PUBLIC_LAWDESK_OFFLINE_MODE=true
AICORE_OFFLINE_MODE=true
AI_CORE_DEFAULT_PROVIDER=local

# ai-core local
AICORE_API_BASE_URL=http://127.0.0.1:8000

# endpoint real do modelo local
# Para Ollama e a maioria dos runtimes locais sem auth, LOCAL_LLM_API_KEY e
# LOCAL_LLM_AUTH_TOKEN podem ficar vazios.
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=aetherlab-legal-local-v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_AUTH_TOKEN=

# aliases alternativos aceitos
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=aetherlab-legal-local-v1
LLM_API_KEY=
LLM_AUTH_TOKEN=

# obsidian local
DOTOBOT_OBSIDIAN_VAULT_PATH=D:\Obsidian\hermidamaia

# extensao local
UNIVERSAL_LLM_EXTENSION_BASE_URL=http://127.0.0.1:32123
UNIVERSAL_LLM_DEFAULT_BASE_PATH=D:\Obsidian\hermidamaia

# Supabase local - fase 2/offline estruturado
SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
